# What graphify should NOT index. Goal: the graph holds SOURCE only, so
# query/path/explain pinpoint code instead of drowning in deps, build output,
# generated data dumps, and logs. Keep this lean and source-focused.

# --- machine-local agent/config (not project source) ---
.claude-bootstrap/
.claude/
CLAUDE.md

# --- dependencies & build output (never source) ---
node_modules/
.next/
out/
build/
.vercel/
package-lock.json

# --- generated data dumps (written by the sync pipeline, not code) ---
# .js files in data/ (e.g. nifty50.js) ARE source and stay indexed.
data/*.json
data/reports/
data/*.xlsx
data/*.csv

# --- runtime logs & debug artifacts ---
*.log
.playwright-mcp/
scripts/*.png
login-*.png
.pw-profile/

# --- throwaway / sandbox ---
_sandbox/
graphify-out/

# --- python caches (mcp/ servers) ---
__pycache__/
*.pyc
.venv/

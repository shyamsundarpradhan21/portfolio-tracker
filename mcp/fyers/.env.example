# Fyers API app credentials — create an app at https://myapi.fyers.in/dashboard
# Copy this file to .env (gitignored) and fill in. NEVER commit real values.
FYERS_APP_ID=XXXXXXXXXX-100
FYERS_SECRET_ID=your_app_secret
FYERS_REDIRECT_URI=https://127.0.0.1/fyers

# Trading PIN — enables the 15-day refresh-token auto-login (mint the daily
# access token with no browser login). Leave blank to log in manually each day.
FYERS_PIN=

# Unattended login (login.py) — renews the 15-day refresh token with NO browser
# prompt via the authenticator-TOTP "Client ID" path. Leave blank to renew by hand.
#   FYERS_FY_ID     your Fyers login Client ID (e.g. XS01234)
#   FYERS_TOTP_SEED base32 secret captured when enabling External TOTP (the SEED,
#                   not a 6-digit code) — store it here, gitignored, never commit
FYERS_FY_ID=
FYERS_TOTP_SEED=

# Optional: a pre-generated daily access token (skips the login tools this session)
# FYERS_ACCESS_TOKEN=

# SAFETY: 1 = read-only (default). Set to 0 to ARM order placement.
# Keep this at 1 for any account holding client capital.
FYERS_READONLY=1

# Upstox API app credentials — create a FREE app at
# https://account.upstox.com/developer/apps (note the API Key + Secret, set a
# Redirect URI). Copy this file to .env (gitignored) and fill in. NEVER commit.
UPSTOX_CLIENT_ID=your_api_key
UPSTOX_CLIENT_SECRET=your_api_secret
UPSTOX_REDIRECT_URI=https://127.0.0.1/upstox

# Unattended daily login (login.py) — drives the OAuth dialog with your
# authenticator TOTP. Enable "Time-based OTP (TOTP)" in Upstox first
# (account.upstox.com -> security) and capture the base32 SEED at QR time.
UPSTOX_MOBILE=10_digit_login_mobile
UPSTOX_TOTP_SEED=base32_seed_from_time_based_otp_setup
UPSTOX_PIN=your_6_digit_pin

# Optional: a pre-generated daily access token (skips login.py this session)
# UPSTOX_ACCESS_TOKEN=

# SAFETY: 1 = read-only (default). Set to 0 to ARM order placement.
# Keep this at 1 for any account holding client capital.
UPSTOX_READONLY=1

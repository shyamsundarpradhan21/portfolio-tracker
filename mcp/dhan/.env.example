# Dhan API credentials — from Dhan Web > DhanHQ Trading APIs (https://dhanhq.co).
# Copy this file to .env (gitignored) and fill in. NEVER commit real values.
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_PIN=your_6_digit_pin

# One-time: click "Set-up TOTP" -> "Add TOTP" on the DhanHQ dashboard, and capture
# the base32 SECRET (the seed, not a 6-digit code). The server uses it to self-mint
# the daily 24h access token via the pure-API endpoint — no browser, no schedule.
DHAN_TOTP_SEED=base32_totp_seed

# SAFETY: 1 = read-only (default). Set to 0 to ARM order placement
# (order APIs also require a registered static IP at DhanHQ; reads do not).
DHAN_READONLY=1

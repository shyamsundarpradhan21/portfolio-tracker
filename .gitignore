# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# local agent tooling (graphify / claude)
/CLAUDE.md
# .claude — track shareable project config (agents/commands/hooks/skills);
# keep the machine/secret-bearing bits local:
/.claude/settings.json
/.claude/settings.local.json
/.claude/statusline.js
/.claude/skills/sync/
# Ignore the volatile graph internals, but COMMIT the portable artifacts so a
# graph built in a cloud session survives into local (Windows) sessions — local
# Claude Code reads these directly since the graphify CLI is cloud-only.
/.graphify/*
!/.graphify/graph.json
!/.graphify/GRAPH_REPORT.md
!/.graphify/wiki/
!/.graphify/wiki/**
/graphify-out/

# misc
.DS_Store
*.pem

# personal financial documents — never commit (real name + tax/holdings data)
*.xlsx
*.xls
*.csv
*.pdf
# raw broker tax/P&L report drop — any extension; PII never leaves this folder, only the
# extracted figures get written into the committed JSONs.
/data/reports/

# throwaway mail-parser spike (branch claude/mail-parser-spike) — sensitive contract-note
# samples (account#/PAN/holdings/P&L). The ENTIRE folder is deletable + must NEVER be
# committed; raw mail stays here and nowhere else. `rm -rf _sandbox` leaves zero trace.
/_sandbox/

# private portfolio data — holdings/salary/loans, pulled out of the bundle into KV.
# Local dev + the KV seed read this; the deployed app reads KV. .example is committed.
/data/portfolio.private.json

# Track B Dhan-Algos catalog research feed — reproducible (browser-harvest → importer)
# and published to KV `algo-catalog:v1`. Large (per-algo correlation matrices) and
# regenerated monthly, so kept out of git: raw harvest, paste fallback, and the snapshot.
/data/algo-catalog.raw.json
/data/algo-catalog.paste.csv
/data/algo-catalog.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# contract-parser tool: family PANs live ONLY here, never committed (the bare `.env` above
# already covers it; this explicit entry is belt-and-suspenders since a PAN reaching the repo
# is the one thing to prevent absolutely). The .example (placeholders) IS committed.
/scripts/contract-parser/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# session debug artifacts — screenshots + browser tooling, not for the repo
/.playwright-mcp/
/scripts/*.png

# script run logs (machine-specific output: sync, capture daemons, etc.)
/scripts/*.log

# python (mcp servers under mcp/)
__pycache__/
*.pyc
.venv/
.token.json

# transient Kite dumps (written by /sync, merged + deleted by merge-*.mjs)
/data/.kite-holdings.json
/data/.kite-trades.json
/data/.kite-market.json

# broker SDK logs written to repo root (may contain request data)
fyersApi.log
fyersRequests.log

# playwright login profile + debug screenshots (machine-specific; screenshots
# can show the login page / client id — never commit)
.pw-profile/
login-*.png

# local MCP client config — machine-specific paths + broker secrets, never commit
/.mcp.json

# laptop KV credentials for the Fyers refresh-token handoff (the .example is committed)
/mcp/.kv.env

# transient cloud secrets bundle — copy to the Remote workspace, then delete
/cloud-secrets.txt
.serena/

# responsive-audit artifacts that render REAL private portfolio figures — never commit
/audit/responsive/shots/
/audit/responsive/*-mock.html

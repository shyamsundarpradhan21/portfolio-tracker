# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# local agent tooling (graphify / claude)
/CLAUDE.md
# .claude — track shareable project config (agents/commands/hooks/skills);
# keep the machine/secret-bearing bits local:
/.claude/settings.json
/.claude/settings.local.json
/.claude/statusline.js
/.claude/skills/sync/
# Ignore the volatile graph internals, but COMMIT the portable artifacts so a
# graph built in a cloud session survives into local (Windows) sessions — local
# Claude Code reads these directly since the graphify CLI is cloud-only.
/.graphify/*
!/.graphify/graph.json
!/.graphify/GRAPH_REPORT.md
!/.graphify/wiki/
!/.graphify/wiki/**
/graphify-out/

# misc
.DS_Store
*.pem

# personal financial documents — never commit (real name + tax/holdings data)
*.xlsx
*.xls
*.csv
*.pdf
# raw broker tax/P&L report drop — any extension; PII never leaves this folder, only the
# extracted figures get written into the committed JSONs.
/data/reports/

# throwaway mail-parser spike (branch claude/mail-parser-spike) — sensitive contract-note
# samples (account#/PAN/holdings/P&L). The ENTIRE folder is deletable + must NEVER be
# committed; raw mail stays here and nowhere else. `rm -rf _sandbox` leaves zero trace.
/_sandbox/

# private portfolio data — holdings/salary/loans, pulled out of the bundle into KV.
# Local dev + the KV seed read this; the deployed app reads KV. .example is committed.
/data/portfolio.private.json

# EOD book — durable per-holding close snapshot + reconcile (scripts/build-eod-book.mjs).
# Private (per-holding values); dormant (nothing reads it yet). Design: tasks/eod-book-design.md.
/data/eod-book.json

# Trading-business contributions/drawings ledger (scripts/build-trading-ledger.mjs).
# Private (real fund amounts); dormant. 100% owner capital. Design: tasks/business-entity-model.md.
/data/trading-ledger.json

# Track B Dhan-Algos catalog research feed — reproducible (browser-harvest → importer)
# and published to KV `algo-catalog:v1`. Large (per-algo correlation matrices) and
# regenerated monthly, so kept out of git: raw harvest, paste fallback, and the snapshot.
/data/algo-catalog.raw.json
/data/algo-catalog.paste.csv
/data/algo-catalog.json

# Track B (Stratzy) — daily live+backtest capture + Dhan join. Reproducible
# (browser-harvest → importer) and KV-backed; large (daily curves + correlation
# matrices). Raw captures, paste fallback, and the joined snapshot stay out of git.
/data/stratzy-raw.json
/data/stratzy-daily.paste.csv
/data/stratzy-daily.json
/data/dhan-full.raw.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# contract-parser tool: family PANs live ONLY here, never committed (the bare `.env` above
# already covers it; this explicit entry is belt-and-suspenders since a PAN reaching the repo
# is the one thing to prevent absolutely). The .example (placeholders) IS committed.
/scripts/contract-parser/.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# session debug artifacts — screenshots + browser tooling, not for the repo
/.playwright-mcp/
/scripts/*.png

# script run logs (machine-specific output: sync, capture daemons, etc.)
/scripts/*.log

# python (mcp servers under mcp/)
__pycache__/
*.pyc
.venv/
.token.json

# transient Kite dumps (written by /sync, merged + deleted by merge-*.mjs)
/data/.kite-holdings.json
/data/.kite-trades.json
/data/.kite-market.json

# broker SDK logs written to repo root (may contain request data)
fyersApi.log
fyersRequests.log

# playwright login profile + debug screenshots (machine-specific; screenshots
# can show the login page / client id — never commit)
.pw-profile/
login-*.png

# local MCP client config — machine-specific paths + broker secrets, never commit
/.mcp.json

# laptop KV credentials for the Fyers refresh-token handoff (the .example is committed)
/mcp/.kv.env

# ── unified ingestion pipeline ────────────────────────────────────────────────
# Source-document intake: raw PDFs/JSONs (contract notes, CAS, payslips, ITR)
# live here transiently — PASS deletes the clone, FAIL/UNRECOGNIZED quarantines
# inside. NOTHING under inbox/ is ever committed.
/inbox/
# Ingestion ledger + Gmail idempotency state (machine-local, PII-adjacent provenance).
# gmail-state*.json = per-account (self + mom + …).
/data/ingest-manifest.json
/data/gmail-state.json
/data/gmail-state.*.json
# Gmail credentials: OAuth desktop client, Pub/Sub subscriber SA key, per-account token
# caches (.token.json = self, .token.<label>.json = additional mailboxes e.g. mom's Kite).
/mcp/gmail/.client_secret.json
/mcp/gmail/.sa.json
/mcp/gmail/.token.json
/mcp/gmail/.token.*.json
# CAS statement passwords (PAN-derived) — same discipline as contract-parser/.env
/scripts/cas-parser/.env
# ITR-derived candidate seeds — carry FY financial detail; applied only via sign-off
/data/itr-candidate-*.json

# transient cloud secrets bundle — copy to the Remote workspace, then delete
/cloud-secrets.txt
.serena/

# responsive-audit artifacts that render REAL private portfolio figures — never commit
/audit/responsive/shots/
/audit/responsive/*-mock.html

# Held basket (personal: which algos the user runs)
/data/held-algos.json

# Screen output (renders the user's held-algo analysis)
/audit/algo-screen.md
# Structured screen payload (held names + capital tier → /api/algo-screen; KV is prod source)
/data/algo-screen.json
# Eyeball-only render shots (binaries; not committed)
/audit/algo-review-shots/

# Regime classifier inputs (regenerable: public Nifty/VIX from Yahoo)
/data/regime-inputs.json

# Monthly algo decision artifacts (derived from gitignored harvest; KV is prod source)
/data/algo-monthly/

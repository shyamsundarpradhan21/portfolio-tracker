# Tool-written data files are always LF (the Node sync/capture/backfill scripts
# write LF). Pin them so Git on Windows stops converting to CRLF and showing the
# files as modified on every checkout. Windows scripts (.cmd/.ps1) keep CRLF.
data/*.json      text eol=lf
data/SNAPSHOT.md text eol=lf
*.cmd            text eol=crlf
*.ps1            text eol=crlf

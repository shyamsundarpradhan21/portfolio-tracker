# CAS statement passwords — copy to .env (gitignored) and fill.
# CAMS/KFintech CAS PDFs are usually keyed on PAN (uppercase) or PAN+DOB —
# add one CAS_PW_* entry per convention you receive; run.py tries each in order.
# NEVER commit .env. Values live in memory only and are never logged.
CAS_PW_SELF=
CAS_PW_ALT=

# Optional KV override — otherwise mcp/.kv.env is used (same as contract-parser).
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# contract-parser — copy to .env (gitignored) and fill in real values. NEVER commit real PANs.
#
# Contract-note PDFs are PAN-locked. The runner tries EVERY CN_PW_* against each note;
# whichever decrypts it wins (you can't mis-tag - the wrong PAN won't open it). The
# owner / tax-entity is 'mom' ONLY for CN_PW_MOM; every other account is 'self'.
CN_PW_SELF=
CN_PW_MOM=
# Optional, only if a broker locks with a different scheme than the self PAN:
# CN_PW_UPSTOX=
# CN_PW_DHAN=
# CN_PW_FYERS=

# Vercel KV (Upstash REST) for pushing the extracted ledger. If unset, the runner falls
# back to the existing creds in mcp/.kv.env.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
